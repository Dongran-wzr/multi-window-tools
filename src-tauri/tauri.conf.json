{
  "$schema": "https://raw.githubusercontent.com/nickkuk/nickk.github.io/main/src/schemas/tauri-2-schema.json",
  "productName": "MultiWindow Terminal",
  "version": "1.0.0",
  "identifier": "com.multiwindow.terminal",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MultiWindow Terminal",
        "width": 1024,
        "height": 640,
        "minWidth": 640,
        "minHeight": 480,
        "center": true,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
